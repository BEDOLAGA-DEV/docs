{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Bedolaga Docs",
  "colors": {
    "primary": "#6366f1",
    "light": "#818cf8",
    "dark": "#4f46e5"
  },
  "favicon": "/images/favicon.png",
  "logo": {
    "light": "/images/logo-navbar.png",
    "dark": "/images/logo-navbar.png"
  },
  "navbar": {
    "links": [
      {
        "label": "Telegram",
        "href": "https://t.me/+wTdMtSWq8YdmZmVi"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "href": "https://github.com/BEDOLAGA-DEV/remnawave-bedolaga-telegram-bot"
    }
  },
  "api": {
    "playground": {
      "mode": "simple"
    },
    "auth": {
      "name": "X-API-Key"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Документация",
        "groups": [
          {
            "group": "Введение",
            "pages": [
              "introduction"
            ]
          },
          {
            "group": "Начало работы",
            "pages": [
              "getting-started/quickstart",
              "getting-started/requirements",
              "getting-started/docker-deployment",
              "getting-started/environment",
              "getting-started/initial-setup",
              "getting-started/smtp-setup",
              "getting-started/troubleshooting"
            ]
          },
          {
            "group": "Бот",
            "pages": [
              "bot/overview",
              "bot/user-onboarding",
              "bot/channel-subscription",
              "bot/payments",
              "bot/subscriptions",
              "bot/tariffs",
              "bot/auto-purchase",
              "bot/promo-system",
              "bot/referral-program",
              "bot/campaigns",
              "bot/contests",
              "bot/notifications",
              "bot/support-system",
              "bot/interface-settings",
              "bot/maintenance",
              "bot/nalogo-setup",
              "bot/traffic-monitoring",
              "bot/admin-notifications",
              "bot/admin-panel"
            ]
          },
          {
            "group": "Cabinet",
            "pages": [
              "cabinet/overview",
              "cabinet/setup",
              "cabinet/proxy-config",
              "cabinet/email-auth",
              "cabinet/oauth-setup",
              "cabinet/rbac",
              "cabinet/backgrounds",
              "cabinet/analytics-setup"
            ]
          },
          {
            "group": "Интеграции",
            "pages": [
              "integrations/remnawave",
              "integrations/webhooks",
              "integrations/egames-auth"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "openapi": "/openapi.json",
        "groups": [
          {
            "group": "Обзор",
            "pages": [
              "api-reference/overview"
            ]
          }
        ]
      },
      {
        "tab": "Разработка",
        "groups": [
          {
            "group": "Для разработчиков",
            "pages": [
              "development/architecture",
              "development/database",
              "development/contributing"
            ]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "GitHub Bot",
          "href": "https://github.com/BEDOLAGA-DEV/remnawave-bedolaga-telegram-bot",
          "icon": "github"
        },
        {
          "anchor": "GitHub Cabinet",
          "href": "https://github.com/BEDOLAGA-DEV/bedolaga-cabinet",
          "icon": "browser"
        }
      ]
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/BEDOLAGA-DEV"
    }
  }
}
